{
  "name": "@octivas/mcp",
  "version": "0.1.4",
  "description": "MCP server for Octivas web scraping, crawling, and search API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "octivas-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "octivas",
    "mcp",
    "model-context-protocol",
    "scraping",
    "web-scraping",
    "crawling",
    "search",
    "ai"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/octivas/octivas-mcp"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@octivas/sdk": "^0.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
